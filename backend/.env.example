# App Settings
ENV=development
PORT=8000
DB_NAME=rag_pdf_db
CLEAR_DB_ON_STARTUP=false
CORS_ORIGINS=["http://localhost:5173"]

# LLM Provider Configuration (groq, ollama, or openrouter)
LLM_PROVIDER=groq
# Embeddings always use fastembed (BAAI/bge-small-en-v1.5) — no config needed

# OpenRouter Settings (Required if LLM_PROVIDER=openrouter)
# Get a key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# Groq Settings (Required if LLM_PROVIDER=groq)
# Get a key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search Settings (Required for BREACH contract audit precedent search)
# Get a free key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Local Ollama Settings (Optional, used only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# MongoDB Connection Settings
# Local MongoDB: mongodb://localhost:27017
# Atlas Cloud: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
