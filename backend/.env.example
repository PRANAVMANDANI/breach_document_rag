# App Settings
ENV=development
PORT=8000
DB_NAME=rag_pdf_db
CLEAR_DB_ON_STARTUP=true
CORS_ORIGINS=["http://localhost:5173"]

# LLM Provider Configuration (gemini, groq, or ollama)
LLM_PROVIDER=groq
# Embedding Provider Configuration (gemini, local, or ollama)
EMBEDDING_PROVIDER=local

# Google Gemini Settings (Required if EMBEDDING_PROVIDER=gemini)
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Settings (Required if LLM_PROVIDER=groq)
# Get a key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Local Ollama Settings (Optional, used if LLM_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# MongoDB Connection Settings
# Local MongoDB: mongodb://localhost:27017
# Atlas Cloud: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
